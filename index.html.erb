---
layout: default
---

<% [
  { lang: "en", title: "SELECTED WORKS", desc_key: "desc", more: "more.." },
  { lang: "ja", title: "作品集", desc_key: "desc_ja", more: "さらに表示.." }
].each do |lang| %>

<div class="one-half column">

<% if lang[:lang] == "ja" %>
<section>
<img alt="lotus" src="/assets/images/top.webp" width="1000" height="1000" style="width:100%; height:auto;">
</section>
<% end %>

<section>

<h1><%= lang[:title] %></h1>

<% @content_data.each do |name, info| %>
<article>
    <h2><a href="<%= info['url'] %>"><%= name %></a></h2>
    <ul>
        <li style="<%= "text-align: justify;" if lang[:lang] == "en" %>">
        <b><%= lang[:lang] == "en" ? "<i>Abstract</i>" : "概要" %></b> - <%= info[lang[:desc_key]] %>
        </li>

        <li>
        <b><%= lang[:lang] == "en" ? "<i>Keywords: </i>" : "キーワード: " %></b>
        <%= info['tags'].sort_by { |s| s.upcase }.join(", ") %>
        </li>
    </ul>
</article>
<div class="spacer"></div>
<% end %>

<a href="/docs/"><%= lang[:more] %></a>

</section>
</div>

<% end %>
