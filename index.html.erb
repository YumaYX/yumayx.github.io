---
layout: default
---

<div class="row">

<div class="one-half column">
<section>

<h2>SELECTED WORKS</h2>

<div class="spacer"></div>

<ul>
  <% @content_data.each do |r| %>
    <% name = r.first %>
    <% info = r.last %>
    <li>
      <a href="<%= info['url'] %>"><%= name %></a>
      <ul>
      <p><i><b>Abstract</b></i> - <%= info['desc'] %></p>
      <p><i><b>Keywords: </b></i><%= info['tags'].sort.join(", ") %></p>
      </ul>
    </li>
    <div class="spacer"></div>
  <% end %>
</ul>


</section>
</div>

<div class="one-half column">
<section>
<img alt="lotus" src="/assets/images/lotus.webp" width="1000" height="1000" style="width:100%; height:auto;">
<a href="/docs/">more..</a>
</section>
</div>

</div>
