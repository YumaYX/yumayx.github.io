<% require 'json' %>
<% jsonlinks = JSON.parse(File.read("./data/links.json")) %>
<% info = JSON.parse(File.read("./data/info.json")) %>

<% jsonlinks.each do |k, v| %>
<h4><%= k %></h4>
<ul>
<% jsonlinks[k].sort.each do |ltitle,inf| %>
<li><a href="<%= inf["url"] %>"><%= ltitle %></a></li>
<% end %>
</ul>
<% end %>

<%info.each do |k,v| %>
<h4><%= k %></h4>
<ul>
<% info[k].sort.each do |key, value| %>
<% item = key %>
<% if info[k].is_a?(Hash) %>
<% item = (item + ": #{value}") %>
<% elsif info[k].is_a?(Array) %>
<%= info[k].sort.join(' / ') %>
<% break %>
<% end %>
<li><%= item %></li> 
<% end %>
</ul>
<% end %>